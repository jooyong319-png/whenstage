# Supabase (Vercel Settings → Environment Variables 에 등록)
# Publishable key는 클라이언트 노출 OK (RLS로 보호됨)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-KEY

# ── 웹 푸시 알림 ──
# VAPID 공개키(클라 노출 OK). 비공개키는 절대 커밋 금지(서버 전용).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
VAPID_PRIVATE_KEY=YOUR-VAPID-PRIVATE-KEY
VAPID_SUBJECT=mailto:devju546@gmail.com
# cron이 구독 테이블 전체를 읽기 위한 service_role 키(서버 전용, 절대 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# /api/cron/notify 보호용 시크릿(Vercel Cron이 Authorization 헤더로 전송)
CRON_SECRET=YOUR-RANDOM-SECRET

# 뉴스 온디맨드 번역(DeepL, 서버 전용). 무료 티어 키는 ":fx" 접미사가 붙음.
DEEPL_API_KEY=YOUR-DEEPL-API-KEY

# /admin 대시보드 보호용 비밀번호(선택). 안 넣으면 비밀번호 없이 열림
# (거기 보여주는 조회수 데이터 자체는 공개 anon 키로도 조회 가능해서 치명적이진 않음).
NEXT_PUBLIC_ADMIN_PASS=YOUR-ADMIN-PASSWORD
